generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt @default(now())
  userId    String  
  user      User     @relation(fields: [userId], references: [id])
  reactions Reaction[]

}

model User {
  id    String    @id @default(cuid())
  email String @unique
  password String
  name  String
  posts Post[] 
  role Role @default(USER)
   reactions Reaction[]
}

enum Role {
  USER
  MODERATOR
  ADMIN
}

enum ReactionType {
  LIKE
  LOVE
  SAD
  WOW
  HAHA
  ANGRY
}

model Reaction {
  userId String
  postId String
  user User @relation(fields: [userId], references: [id])
  post Post @relation(fields: [postId], references:[id])
  type ReactionType
  createdAt DateTime @default(now())
  @@id(name:"reactionId", [postId, userId])
}
